# ── Authentication ────────────────────────────────────────────────────────────
# Your 8x8 Work login credentials — the server uses Puppeteer to sign in
# automatically and extract session cookies. No manual cookie copying needed.
EIGHT_BY_EIGHT_USERNAME=you@example.com
EIGHT_BY_EIGHT_PASSWORD=yourpassword

# PBX / Queue config ──────────────────────────────────────────────────────────
# PBX ID — from the analytics page URL: /pbxes/{THIS_VALUE}/
EIGHT_BY_EIGHT_PBX_ID=3xm936RGQ6mOW3rasgwUtA

# Short PBX name used for CDR queries (visible in the 8x8 admin portal)
EIGHT_BY_EIGHT_PBX_NAME=southbridgecareho

# Queue ID(s) to monitor — comma-separated if you have multiple queues
EIGHT_BY_EIGHT_QUEUE_IDS=CoWScuh6QKy1Qt16vPAylQ

# Queue name for CDR filtering (partial match, case-insensitive)
EIGHT_BY_EIGHT_QUEUE_NAME=Help Desk

# Timezone for daily stats
EIGHT_BY_EIGHT_TIMEZONE=Canada/Eastern

# Server port
PORT=3001
